# Entornos virtuales
venv/
.venv/
env/

# Python
__pycache__/
*.pyc
*.pyo

# Configuración local sensible (IP/puerto del móvil de cada usuario — ver config.example.json)
.env
config.json

# Datos de ejemplo/pruebas locales (pueden contener información financiera real)
samples/

# Historial personal de conciliación (por usuario, no es código del proyecto)
data/

# Logs de diagnóstico (pueden contener descripciones de transacciones reales)
logs/

# Artefactos de compilación de PyInstaller (ver build_exe.spec) -- se regeneran en cada build,
# no se versionan. El .spec sí se versiona, es código fuente de la build.
build/
dist/
*.exe
